{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "kraken-engine",
  "version-semver": "1.7.1",
  "description": "A 2D videogame development framework.",
  "homepage": "https://krakenengine.org/",
  "builtin-baseline": "0b88aacde46a853151730fbe7d0b7ee45f4b6864",
  "dependencies": [
    "box2d",
    "pugixml",
    {
      "name": "sdl3",
      "features": [
        "vulkan"
      ]
    },
    {
      "name": "sdl3-image",
      "features": [
        "jpeg",
        "png"
      ]
    },
    {
      "name": "sdl3-mixer",
      "features": [
        "libflac",
        "libvorbis",
        "mpg123",
        "opusfile"
      ]
    },
    "sdl3-shadercross",
    {
      "name": "sdl3-ttf",
      "features": [
        "harfbuzz"
      ]
    },
    {
      "name": "spdlog",
      "features": [
        "fmt"
      ]
    },
    "tmxlite",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zstd"
  ],
  "overrides": [
    {
      "name": "box2d",
      "version": "3.1.1"
    },
    {
      "name": "sdl3",
      "version": "3.4.0"
    },
    {
      "name": "sdl3-image",
      "version": "3.4.0"
    },
    {
      "name": "sdl3-mixer",
      "version": "3.2.0"
    },
    {
      "name": "sdl3-ttf",
      "version": "3.2.2"
    },
    {
      "name": "spdlog",
      "version": "1.17.0"
    },
    {
      "name": "tmxlite",
      "version": "1.4.5"
    },
    {
      "name": "zstd",
      "version": "1.5.7"
    }
  ]
}
